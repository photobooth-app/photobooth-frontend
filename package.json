{
  "name": "photobooth-app",
  "version": "2.0.0",
  "description": "photobooth-app frontend",
  "productName": "Photobooth-App",
  "author": "michael <me@mgrl.de>",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint ./**/*.{js,ts,mjs,cjs,vue}",
    "lint:fix": "eslint --fix ./**/*.{js,ts,mjs,cjs,vue}",
    "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "generate-types": "openapi-typescript  http://localhost:8000/api/openapi.json --output ./src/dto/api.ts",
    "check-types": "openapi-typescript  http://localhost:8000/api/openapi.json --output ./src/dto/api.ts --check",
    "test": "echo \"No test specified\" && exit 0",
    "dev": "quasar dev",
    "build": "quasar build",
    "postinstall": "quasar prepare"
  },
  "dependencies": {
    "@jsonforms/core": "^3.7.0",
    "@jsonforms/vue": "^3.8.0",
    "@quasar/extras": "^2.0.1",
    "@vueuse/core": "^14.3.0",
    "@vueuse/integrations": "^14.3.0",
    "pinia": "^3.0.4",
    "qrcode.vue": "^3.10.0",
    "quasar": "^2.20.1",
    "vue": "^3.5.38",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@intlify/eslint-plugin-vue-i18n": "^4.5.1",
    "@intlify/unplugin-vue-i18n": "^11.2.4",
    "@quasar/app-vite": "^2.6.2",
    "@types/lodash": "^4.17.24",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.8.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.5.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "vite-plugin-checker": "^0.14.4",
    "vue-tsc": "^3.3.5"
  },
  "engines": {
    "node": "^28 || ^26 || ^24 || ^22 || ^20 || ^18",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  }
